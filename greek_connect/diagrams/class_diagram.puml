@startuml
title GreekConnect Class Diagram (Current lib/)

skinparam classAttributeIconSize 0
hide empty methods

package "Core App" {
  class gcMyApp <<StatelessWidget>>
  class gcMyHomePage <<StatefulWidget>>
  class _gcMyHomePageState <<State<gcMyHomePage>>> {
    - int selectedIndex
  }
  class gcDefaultFirebaseOptions <<Config>>
}

package "Auth" {
  class gcAuthPage <<StatelessWidget>>
  class gcLoginOrRegister <<StatefulWidget>>
  class _gcLoginOrRegisterState <<State<gcLoginOrRegister>>> {
    - bool showLogin
  }
  class gcLoginScreen <<StatefulWidget>>
  class _gcLoginScreenState <<State<gcLoginScreen>>
  class gcRegisterScreen <<StatefulWidget>>
  class _gcRegisterScreenState <<State<gcRegisterScreen>>
}

package "Screens" {
  class gcDashboardScreen <<StatefulWidget>>
  class _gcDashboardScreenState <<State<gcDashboardScreen>>> {
    - Future<List<gcEvent>> _upcomingRsvpEvents
  }

  enum CalendarMode {
    edit
    rsvp
  }

  class gcCalendarScreen <<StatefulWidget>>
  class _gcCalendarScreenState <<State<gcCalendarScreen>>> {
    - ValueNotifier<List<gcEvent>> _selectedEvents
    - Map<DateTime, List<gcEvent>> _events
    - DateTime _focusedDay
    - DateTime? _selectedDay
    - CalendarMode _mode
    - bool _isLoading
  }

  class _CalendarEventList <<StatelessWidget>> {
    - List<gcEvent> events
    - CalendarMode mode
  }

  class gcNotificationsScreen <<StatefulWidget>>
  class _gcNotificationsScreenState <<State<gcNotificationsScreen>>> {
    - Future<List<gcEvent>> _upcomingRsvpEvents
  }

  class gcOrganizationsScreen <<StatelessWidget>>
  class ProfileSetupScreen <<StatefulWidget>>
  class _ProfileSetupScreenState <<State<ProfileSetupScreen>>
  class gcSettingsScreen <<StatefulWidget>>
  class _gcSettingsScreenState <<State<gcSettingsScreen>>> {
    - UserService _userService
    - bool _isLoading
    - bool newEvents
    - bool myUpcomingEvents
    - bool houseUpdates
    - bool urgentUpdates
    - bool outlook
    - bool textMessages
  }
}

package "Widgets" {
  class gcEventFormModal <<StatefulWidget>> {
    + DateTime selectedDate
    + gcEvent? initialEvent
  }
  class _gcEventFormModalState <<State<gcEventFormModal>>> {
    - GlobalKey<FormState> _formKey
    - String _title
    - String _description
    - String _location
    - TimeOfDay? _startTime
    - TimeOfDay? _endTime
  }

  class EventRsvpModal <<StatefulWidget>> {
    + gcEvent event
  }
  class _EventRsvpModalState <<State<EventRsvpModal>>> {
    - bool _isSaving
    - bool? _alreadyRsvpd
  }

  class gcMyTextField <<StatelessWidget>>
}

package "Models" {
  class gcEvent {
    + String id
    + String title
    + String? description
    + DateTime date
    + int color
    + String? location
    + String? userId
    + TimeOfDay? startTime
    + TimeOfDay? endTime
    + Map<String, dynamic> toJson()
    + gcEvent copyWith(...)
  }

  class UserProfile {
    + String uid
    + String email
    + String? displayName
    + String? organization
    + DateTime createdAt
    + DateTime? lastLoginAt
    + Map<String, dynamic> toMap()
    + UserProfile copyWith(...)
  }
}

package "Services" {
  class gcEventStorage <<Service>> {
    {static} + loadEvents()
    {static} + saveEvents(...)
    {static} + addEvent(...)
    {static} + removeEvent(...)
    {static} + updateEvent(...)
    {static} + clearAllEvents()
    {static} + getEventsForDate(...)
    {static} + getEventsForRange(...)
  }

  class RsvpService <<Service>> {
    {static} + getUpcomingRsvpEvents(...)
  }

  class UserService <<Service>> {
    + userProfileExists(...)
    + getUserProfile(...)
    + createUserProfile(...)
    + updateUserProfile(...)
    + updateLastLogin(...)
    + updateOrganization(...)
    + getNotificationPreferences(...)
    + saveNotificationPreferences(...)
  }

  class OktaAuthService <<Service>> {
    {static} + generatePKCE()
    {static} + storeCodeVerifier(...)
    {static} + getCodeVerifier()
    {static} + clearCodeVerifier()
    {static} + exchangeCodeForTokens(...)
    {static} + getUserInfo(...)
  }

  class OAuthCallbackService <<Service>> {
    {static} + handleOAuthCallback()
  }
}

' StatefulWidget <-> State ownership
gcMyHomePage *-- _gcMyHomePageState
gcLoginOrRegister *-- _gcLoginOrRegisterState
gcLoginScreen *-- _gcLoginScreenState
gcRegisterScreen *-- _gcRegisterScreenState
gcDashboardScreen *-- _gcDashboardScreenState
gcCalendarScreen *-- _gcCalendarScreenState
gcNotificationsScreen *-- _gcNotificationsScreenState
ProfileSetupScreen *-- _ProfileSetupScreenState
gcSettingsScreen *-- _gcSettingsScreenState
gcEventFormModal *-- _gcEventFormModalState
EventRsvpModal *-- _EventRsvpModalState

' App/navigation wiring
gcMyApp ..> gcMyHomePage : home
gcMyApp ..> gcDefaultFirebaseOptions
gcMyApp ..> OAuthCallbackService
_gcMyHomePageState ..> gcAuthPage
_gcMyHomePageState ..> gcDashboardScreen
_gcMyHomePageState ..> gcCalendarScreen
_gcMyHomePageState ..> gcNotificationsScreen
_gcMyHomePageState ..> ProfileSetupScreen

' Auth flow dependencies
gcAuthPage ..> UserService
gcAuthPage ..> gcDashboardScreen
gcAuthPage ..> ProfileSetupScreen
gcAuthPage ..> gcLoginOrRegister
_gcLoginOrRegisterState ..> gcLoginScreen
_gcLoginOrRegisterState ..> gcRegisterScreen
_gcLoginScreenState ..> gcMyTextField
_gcRegisterScreenState ..> gcMyTextField
_gcLoginScreenState ..> OktaAuthService

' Screen dependencies
_gcDashboardScreenState ..> RsvpService
_gcDashboardScreenState ..> gcEvent
_gcDashboardScreenState ..> gcOrganizationsScreen
_gcDashboardScreenState ..> gcSettingsScreen

_gcCalendarScreenState ..> gcEventStorage
_gcCalendarScreenState ..> gcEventFormModal
_gcCalendarScreenState ..> EventRsvpModal
_gcCalendarScreenState ..> _CalendarEventList
_gcCalendarScreenState ..> gcEvent
_gcCalendarScreenState ..> CalendarMode
_CalendarEventList ..> gcEvent
_CalendarEventList ..> CalendarMode

_gcNotificationsScreenState ..> RsvpService
_gcNotificationsScreenState ..> gcEvent
_ProfileSetupScreenState ..> UserService
_ProfileSetupScreenState ..> UserProfile
_gcSettingsScreenState ..> UserService

' Widget/service/model dependencies
_gcEventFormModalState ..> gcEvent
_EventRsvpModalState ..> gcEvent
RsvpService ..> gcEventStorage
RsvpService ..> gcEvent
gcEventStorage ..> gcEvent
UserService ..> UserProfile
OAuthCallbackService ..> OktaAuthService

@enduml