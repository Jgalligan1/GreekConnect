rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ───────────────────────────────────────────────────────

    // Returns true if the requesting user is authenticated.
    function isSignedIn() {
      return request.auth != null;
    }

    // Returns true if the requesting user is the owner of the document uid.
    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // Reads the caller's user document and checks the isAdmin flag.
    // NOTE: This incurs one extra read per write operation on guarded collections.
    function isAdmin() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    // Checks if the user is an admin of a specific organization.
    // Returns true if user is in the organization's admin list.
    function isAdminOfOrganization(organizationName) {
      return isSignedIn() && (
        organizationName in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.adminForOrganizations
      );
    }

    // ── users collection ───────────────────────────────────────────────────────
    match /users/{uid} {
      // Any signed-in user can read user profiles (needed for organization member lists and queries).
      // NOTE: This is temporary for testing. User data exposed: email, displayName, organization, admin status.
      // TODO: Replace with Cloud Function that validates organization membership before returning members.
      allow read: if isSignedIn();

      // A user can create their own profile on sign-up.
      allow create: if isOwner(uid);

      // Allow updates:
      // 1. A user can always update their own profile
      // 2. An organization admin can update adminForOrganizations or organizations for members of their org
      allow update: if isOwner(uid) ||
        (request.resource.data.keys().hasAny(['adminForOrganizations', 'organizations']) &&
         resource.data.organizations != null &&
         resource.data.organizations.size() > 0 &&
         // Check that caller is admin of at least one org the target user belongs to
         resource.data.organizations.hasAny(
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.adminForOrganizations
         ));

      // ── Production rules (re-enable when testing is done) ─────────────────
      // allow read: if isOwner(uid);
      // allow update: if isOwner(uid) &&
      //   (
      //     !('isAdmin' in request.resource.data) ||
      //     request.resource.data.isAdmin == resource.data.isAdmin
      //   );
      // allow update: if isAdmin();

      // Only admins may delete user profiles.
      allow delete: if isAdmin();
    }

    // ── events collection ──────────────────────────────────────────────────────
    match /events/{eventId} {
      // Anyone signed in can read events (needed for RSVP mode).
      allow read: if isSignedIn();

      // Only admins of the event's organization may create events.
      allow create: if request.resource.data.keys().hasAll(['organization']) &&
        request.resource.data.organization is string &&
        request.resource.data.organization.size() > 0 &&
        isAdminOfOrganization(request.resource.data.organization);

      // Only admins of the event's organization may update or delete events.
      allow update, delete: if isAdminOfOrganization(resource.data.organization);
    }

    // ── rsvps collection ───────────────────────────────────────────────────────
    match /rsvps/{rsvpId} {
      // A user can read their own RSVPs.
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;

      // A signed-in user can create/update/delete their own RSVP.
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // ── in_app_notifications collection ────────────────────────────────────────
    match /in_app_notifications/{notificationId} {
      // A user can read their own notifications.
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;

      // A user can create/update/delete their own notifications.
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // ── invitationCodes collection ─────────────────────────────────────────────
    match /invitationCodes/{codeId} {
      // Any signed-in user can read invitation codes (needed to validate when joining).
      allow read: if isSignedIn();

      // Only organization admins may create invitation codes for their organization.
      allow create: if request.resource.data.keys().hasAll(['organizationName']) &&
        isAdminOfOrganization(request.resource.data.organizationName);

      // Allow updates:
      // - Organization admins can update anything for their org
      // - Signed-in users can increment timesUsed when joining with a valid code
      allow update: if isSignedIn() &&
        ((request.resource.data.keys().hasAll(['organizationName']) &&
          isAdminOfOrganization(request.resource.data.organizationName)) ||
         (request.resource.data.timesUsed == resource.data.timesUsed + 1 &&
          request.resource.data.code == resource.data.code &&
          request.resource.data.organizationName == resource.data.organizationName &&
          request.resource.data.createdBy == resource.data.createdBy &&
          request.resource.data.createdAt == resource.data.createdAt &&
          request.resource.data.expiresAt == resource.data.expiresAt &&
          request.resource.data.usageLimit == resource.data.usageLimit &&
          request.resource.data.isActive == resource.data.isActive));

      // Only organization admins may delete invitation codes for their organization.
      allow delete: if resource.data.keys().hasAll(['organizationName']) &&
        isAdminOfOrganization(resource.data.organizationName);
    }

  }
}
